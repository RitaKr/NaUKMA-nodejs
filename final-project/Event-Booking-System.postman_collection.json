        {
          "name": "Google OAuth – Initiate (open in browser)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            },
            "description": "Open this URL in a browser tab. Google will redirect to the consent screen, then to `/auth/google/callback` which returns `{ token, user }`. Copy the token into `adminToken` or `userToken` collection variable.\n\nRequires `GOOGLE_CLIENT_ID` and `GOOGLE_CLIENT_SECRET` set in the server `.env`."
          },
          "response": []
        },
        {
          "name": "Google OAuth – Callback (auto-called by Google)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google/callback?code=GOOGLE_CODE_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "callback"],
              "query": [{ "key": "code", "value": "GOOGLE_CODE_HERE" }]
            },
            "description": "This endpoint is called automatically by Google after consent. It returns `{ token, user }`. Do not call this manually — use the 'Initiate' request in a browser instead."
          },
          "response": []
        }
      ]
    },
